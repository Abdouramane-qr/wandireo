# Copy this file to .env and fill in the values before starting the service.
# Never commit the actual .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Secret key that clients must supply in the X-API-Key header
API_KEY=change-me-to-a-strong-random-secret

# ── Optional ──────────────────────────────────────────────────────────────────
APP_NAME=Translator API
APP_VERSION=1.0.0
DEBUG=false
