APP_NAME=Wandireo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tripanova.code-ai-insight.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=wandireo
DB_USERNAME=wandireo
DB_PASSWORD=secret
DB_PORT_EXTERNAL=5432

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=wandireo-uploads
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=https://tripanova.code-ai-insight.com/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACER_PAR_VOTRE_CLE
VITE_SENTRY_DSN=

# Stripe (backend)
STRIPE_SECRET_KEY=sk_test_REMPLACER_PAR_VOTRE_CLE
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER_PAR_VOTRE_SECRET

# Sentry (monitoring erreurs backend)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# GeoIP2 (fichier MaxMind local facultatif)
GEOIP_COUNTRY_DB_PATH=

# FareHarbor (catalogue externe)
FAREHARBOR_BASE_URL=https://fareharbor.com/api/v1
FAREHARBOR_TIMEOUT=15
FAREHARBOR_AUTOSYNC_ENABLED=false
FAREHARBOR_AUTOSYNC_FREQUENCY=hourly
FAREHARBOR_AUTOSYNC_TIMEZONE=UTC

# Sanctum (domaines autorises pour les cookies cross-site)
SANCTUM_STATEFUL_DOMAINS=tripanova.code-ai-insight.com

# Ports Docker
APP_PORT=8000
VITE_PORT=5173
NGINX_PORT_EXTERNAL=8080
